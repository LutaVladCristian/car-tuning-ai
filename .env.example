# =============================================================================
# car-backend-ms  (FastAPI auth/proxy — port 8001)
# =============================================================================

# PostgreSQL connection string. For local dev SQLite is fine: sqlite:///./car_backend.db
DATABASE_URL=postgresql://user:password@localhost:5432/car_tuning

# URL of the segmentation microservice (used by the backend proxy)
SEGMENTATION_MS_URL=http://localhost:8000

# Firebase Storage bucket — stores original + result photo images (replaces DB blobs)
# Format: your-project-id.firebasestorage.app
# Local dev: start `firebase emulators:start --only storage` and set FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199
FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app

# Firebase / Google Identity Platform project used to verify user ID tokens
FIREBASE_PROJECT_ID=your-gcp-project-id

# Local dev: run `gcloud auth application-default login` once to set up ADC.
# Cloud Run: ADC is provided automatically by the attached service account.

# =============================================================================
# car-segmentation-ms  (FastAPI ML service — port 8000)
# =============================================================================

# OpenAI API key — required for the /edit-photo endpoint
OPENAI_API_KEY=sk-...

# Optional bucket used by deployed segmentation infrastructure to fetch model weights
MODEL_BUCKET=car-tuning-ai-dev-models

# =============================================================================
# car-frontend  (Vite + React SPA — dev port 5173, prod port 80)
# =============================================================================

# Backend base URL consumed by Vite at BUILD TIME (baked into the JS bundle).
# For local dev this defaults to http://localhost:8001 in vite.config.ts.
# For production Docker builds pass as --build-arg VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=http://localhost:8001

# Firebase project config — consumed by Vite at BUILD TIME.
# Find these in the Firebase console under Project Settings > Your apps > Web app.
VITE_FIREBASE_API_KEY=your-web-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-gcp-project-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
