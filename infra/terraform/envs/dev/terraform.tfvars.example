project_id     = "your-new-gcp-project-id"
project_number = "123456789012"
github_owner   = "your-github-user-or-org"
github_repo    = "car-tuning-ai"

# Defaults are selected for Bucharest proximity plus GPU-capable zones in Europe.
region = "europe-central2"
zone   = "europe-central2-b"

# CI/CD replaces these with Artifact Registry images.
frontend_image     = "us-docker.pkg.dev/cloudrun/container/hello"
backend_image      = "us-docker.pkg.dev/cloudrun/container/hello"
segmentation_image = "us-docker.pkg.dev/cloudrun/container/hello"
